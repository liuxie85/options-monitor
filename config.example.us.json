{
  "fees": {
    "model": {
      "US": "futu_us_simplified",
      "HK": "static"
    },
    "hk_static": {
      "platform_fee_per_order_hkd": 15.0,
      "commission_per_order_hkd": 0.0,
      "other_fees_per_order_hkd": 0.0
    }
  },
  "fetch_policy": {
    "allow_downgrade_to_yahoo": true
  },
  "intake": {
    "symbol_aliases": {
      "中海油": "0883.HK",
      "腾讯": "0700.HK"
    },
    "multiplier_by_symbol": {
      "0883.HK": 1000,
      "0700.HK": 1000
    },
    "default_multiplier_us": 100,
    "default_multiplier_hk": 1000
  },
  "templates": {
    "put_base": {
      "sell_put": {
        "min_otm_pct": 0.05,
        "min_annualized_net_return": 0.1,
        "min_net_income": 100,
        "min_open_interest": 50,
        "min_volume": 10,
        "require_bid_ask": true,
        "max_spread_ratio": 0.3
      }
    },
    "call_base": {
      "sell_call": {
        "min_annualized_net_return": 0.1,
        "min_if_exercised_total_return": 0.05,
        "min_open_interest": 50,
        "min_volume": 10,
        "require_bid_ask": true,
        "max_spread_ratio": 0.3
      }
    }
  },
  "outputs": {
    "top_n_alerts": 3
  },
  "runtime": {
    "symbol_timeout_sec": 120,
    "portfolio_timeout_sec": 60,
    "pipeline_timeout_sec": 600,
    "option_positions_context_ttl_sec": 900,
    "portfolio_context_ttl_sec": 900
  },
  "alert_policy": {
    "sell_put_high_return": 0.12,
    "sell_call_high_return": 0.12,
    "change_annual_threshold": 0.02
  },
  "portfolio": {
    "pm_config": "../portfolio-management/config.json",
    "market": "富途",
    "account": "lx",
    "base_currency": "CNY"
  },
  "notifications": {
    "enabled": true,
    "channel": "feishu",
    "target": "user:YOUR_OPEN_ID",
    "mode": "change_or_high",
    "include_cash_footer": false,
    "cash_footer_accounts": [
      "lx",
      "sy"
    ],
    "cash_footer_timeout_sec": 180,
    "cash_snapshot_max_age_sec": 900,
    "quiet_hours_beijing": {
      "start": "02:00",
      "end": "08:00"
    }
  },
  "schedule": {
    "enabled": true,
    "market_timezone": "America/New_York",
    "market_open": "09:30",
    "market_close": "16:00",
    "monitor_off_hours": false,
    "beijing_timezone": "Asia/Shanghai",
    "notify_cooldown_min": 60,
    "interval_min": 60
  },
  "symbols": [
    {
      "symbol": "NVDA",
      "market": "US",
      "fetch": {
        "limit_expirations": 8,
        "source": "opend",
        "host": "127.0.0.1",
        "port": 11111,
        "spot_from_portfolio_management": true
      },
      "use": [
        "put_base",
        "call_base"
      ],
      "sell_put": {
        "enabled": true,
        "min_dte": 20,
        "max_dte": 90,
        "min_strike": 150,
        "max_strike": 160
      },
      "sell_call": {
        "enabled": false,
        "avg_cost": null,
        "shares": null
      }
    }
  ]
}