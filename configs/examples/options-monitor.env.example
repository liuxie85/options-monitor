# Copy to /etc/options-monitor/options-monitor.env on Linux.
# Fill real values on the server only. Do not commit real secrets.

OM_FEISHU_APP_ID=""
OM_FEISHU_APP_SECRET=""
OM_FEISHU_HOLDINGS_TABLE=""

OM_NOTIFY_FEISHU_APP_ID=""
OM_NOTIFY_FEISHU_APP_SECRET=""

# Feishu inbound gateway. Prefer a dedicated bot app; falls back to
# OM_NOTIFY_FEISHU_APP_ID/OM_NOTIFY_FEISHU_APP_SECRET when the inbound-specific
# app credentials are empty.
OM_INBOUND_FEISHU_APP_ID=""
OM_INBOUND_FEISHU_APP_SECRET=""
OM_INBOUND_FEISHU_ENCRYPT_KEY=""
OM_INBOUND_FEISHU_VERIFICATION_TOKEN=""
OM_INBOUND_ALLOWED_SENDERS="feishu:ou_xxx"
OM_INBOUND_AUDIT_DB="/var/lib/options-monitor/output_shared/state/inbound_control.sqlite3"
OM_FEISHU_GATEWAY_HOST="127.0.0.1"
OM_FEISHU_GATEWAY_PORT="8765"
OM_FEISHU_GATEWAY_PATH="/feishu/events"
