{
  "fees": {
    "model": {
      "US": "futu_us_simplified",
      "HK": "static"
    },
    "hk_static": {
      "platform_fee_per_order_hkd": 15.0,
      "commission_per_order_hkd": 0.0,
      "other_fees_per_order_hkd": 0.0
    }
  },
  "fetch_policy": {
    "allow_downgrade_to_yahoo": false
  },
  "accounts": [
    "lx",
    "sy"
  ],
  "intake": {
    "symbol_aliases": {
      "腾讯": "0700.HK",
      "中海油": "0883.HK"
    },
    "multiplier_by_symbol": {
      "0700.HK": 1000,
      "0883.HK": 1000
    },
    "default_multiplier_us": 100,
    "default_multiplier_hk": 1000
  },
  "templates": {
    "put_base": {
      "sell_put": {
        "min_annualized_net_return": 0.1,
        "min_net_income": 100,
        "min_open_interest": 50,
        "min_volume": 10,
        "max_spread_ratio": 0.3
      }
    }
  },
  "outputs": {
    "top_n_alerts": 3
  },
  "runtime": {
    "symbol_timeout_sec": 120,
    "portfolio_timeout_sec": 60,
    "pipeline_timeout_sec": 600,
    "option_positions_context_ttl_sec": 900,
    "portfolio_context_ttl_sec": 900
  },
  "alert_policy": {
    "sell_put_high_return": 0.12,
    "change_annual_threshold": 0.02
  },
  "portfolio": {
    "pm_config": "secrets/portfolio.feishu.json",
    "market": "富途",
    "account": "lx",
    "base_currency": "CNY"
  },
  "notifications": {
    "enabled": true,
    "channel": "feishu",
    "target": "user:YOUR_OPEN_ID",
    "mode": "change_or_high",
    "quiet_hours_beijing": {
      "start": "02:00",
      "end": "08:00"
    }
  },
  "schedule": {
    "enabled": true,
    "market_timezone": "Asia/Hong_Kong",
    "market_open": "09:30",
    "market_close": "16:00",
    "monitor_off_hours": false,
    "first_notify_after_open_min": 30,
    "notify_interval_min": 60,
    "final_notify_before_close_min": 10,
    "market_break_start": "12:00",
    "market_break_end": "13:00"
  },
  "symbols": [
    {
      "symbol": "0700.HK",
      "market": "HK",
      "fetch": {
        "source": "opend",
        "host": "127.0.0.1",
        "port": 11111,
        "limit_expirations": 8
      },
      "use": "put_base",
      "sell_put": {
        "enabled": true,
        "min_dte": 5,
        "max_dte": 45,
        "min_strike": 0,
        "max_strike": 999999
      },
      "sell_call": {
        "enabled": false
      }
    }
  ]
}
