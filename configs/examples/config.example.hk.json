{
  "accounts": [
    "user1"
  ],
  "account_settings": {
    "user1": {
      "type": "futu"
    }
  },
  "trade_intake": {
    "enabled": true,
    "mode": "dry-run",
    "account_mapping": {
      "futu": {
        "REAL_12345678": "user1"
      }
    }
  },
  "templates": {
    "put_base": {
      "sell_put": {
        "min_otm_pct": 0.05,
        "min_annualized_net_return": 0.1,
        "min_net_income": 300,
        "min_open_interest": 50,
        "min_volume": 0,
        "max_spread_ratio": 0.3
      }
    },
    "call_base": {
      "sell_call": {
        "min_annualized_net_return": 0.1,
        "min_if_exercised_total_return": 0.05,
        "min_open_interest": 50,
        "min_volume": 0,
        "max_spread_ratio": 0.3,
        "min_net_income": 300
      }
    }
  },
  "portfolio": {
    "data_config": "secrets/portfolio.sqlite.json",
    "broker": "富途",
    "account": "user1",
    "source": "futu",
    "base_currency": "CNY"
  },
  "schedule": {
    "enabled": true,
    "market_timezone": "Asia/Hong_Kong",
    "market_open": "09:30",
    "market_close": "16:00",
    "first_notify_after_open_min": 30,
    "notify_interval_min": 60,
    "final_notify_before_close_min": 10,
    "market_break_start": "12:00",
    "market_break_end": "13:00"
  },
  "notifications": {
    "channel": "feishu",
    "target": "ou_xxx",
    "secrets_file": "configs/examples/notifications.feishu.app.example.json"
  },
  "symbols": [
    {
      "symbol": "0700.HK",
      "market": "HK",
      "fetch": {
        "source": "futu",
        "host": "127.0.0.1",
        "port": 11111,
        "limit_expirations": 8
      },
      "use": [
        "put_base",
        "call_base"
      ],
      "sell_put": {
        "enabled": true,
        "min_dte": 5,
        "max_dte": 45,
        "min_strike": 1,
        "max_strike": 999999
      },
      "sell_call": {
        "enabled": false
      }
    }
  ],
  "intake": {
    "symbol_aliases": {
      "腾讯": "0700.HK",
      "中海油": "0883.HK"
    },
    "multiplier_by_symbol": {
      "0700.HK": 1000,
      "0883.HK": 1000
    },
    "default_multiplier_us": 100,
    "default_multiplier_hk": 1000
  },
  "outputs": {
    "top_n_alerts": 3
  },
  "runtime": {
    "symbol_timeout_sec": 120,
    "portfolio_timeout_sec": 60,
    "pipeline_timeout_sec": 600,
    "option_positions_context_ttl_sec": 900,
    "portfolio_context_ttl_sec": 900,
    "option_chain_fetch": {
      "max_calls": 10,
      "window_sec": 30,
      "max_wait_sec": 90
    },
    "opend_rate_limits": {
      "market_snapshot": {
        "max_calls": 60,
        "window_sec": 30,
        "max_wait_sec": 30
      },
      "option_expiration": {
        "max_calls": 30,
        "window_sec": 30,
        "max_wait_sec": 30
      }
    }
  },
  "alert_policy": {
    "change_annual_threshold": 0.02
  },
  "close_advice": {
    "enabled": true,
    "quote_source": "auto",
    "notify_levels": [
      "strong",
      "medium"
    ],
    "max_items_per_account": 5,
    "max_spread_ratio": 0.4,
    "strong_remaining_annualized_max": 0.08,
    "medium_remaining_annualized_max": 0.12
  },
  "fetch_policy": {
    "allow_downgrade_to_yahoo": false
  }
}
